rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        (request.auth.token.email == "jrperfumaria04@gmail.com" || request.auth.token.email == "joaoalexsanderro@gmail.com");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Products Collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow delete: if isAdmin() && isValidId(productId);
    }

    function isValidProduct(data) {
      return data.id is string && data.id.size() <= 128 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
        data.description is string && data.description.size() <= 2000 &&
        data.price is number && data.price >= 0 &&
        data.image is string && data.image.size() <= 2000 &&
        data.category is string && data.category.size() <= 100 &&
        (!('featured' in data) || data.featured is bool);
    }

    // 2. Categories Collection
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(incoming()) && isValidId(categoryId);
      allow update: if isAdmin() && isValidCategory(incoming()) && isValidId(categoryId);
      allow delete: if isAdmin() && isValidId(categoryId);
    }

    function isValidCategory(data) {
      return data.id is string && data.id.size() <= 128 &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.slug is string && data.slug.size() > 0 && data.slug.size() <= 100;
    }

    // 3. Banners Collection
    match /banners/{bannerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBanner(incoming()) && isValidId(bannerId);
      allow update: if isAdmin() && isValidBanner(incoming()) && isValidId(bannerId);
      allow delete: if isAdmin() && isValidId(bannerId);
    }

    function isValidBanner(data) {
      return data.id is string && data.id.size() <= 128 &&
        data.image is string && data.image.size() <= 20000000 &&
        data.title is string && data.title.size() <= 200 &&
        data.subtitle is string && data.subtitle.size() <= 1000 &&
        data.cta is string && data.cta.size() <= 200 &&
        data.active is bool &&
        (!('device' in data) || (data.device is string && data.device.size() <= 20)) &&
        (!('opacity' in data) || (data.opacity is int || data.opacity is float));
    }

    // 4. Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSetting(incoming()) && isValidId(settingId);
      allow update: if isAdmin() && isValidSetting(incoming()) && isValidId(settingId);
      allow delete: if isAdmin() && isValidId(settingId);
    }

    function isValidSetting(data) {
      return data.key is string && data.key.size() <= 100 &&
        data.value is string && data.value.size() <= 20000000;
    }

    // 5. Users Profile and Carts
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow delete: if isAdmin();
    }

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
        data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
        (!('cart' in data) || data.cart is list);
    }

    // 6. Admins List
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidId(adminId);
    }
  }
}
